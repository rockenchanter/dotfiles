{
    "modules-left": [ "sway/workspaces" ],
    "modules-center": [ "clock" ],
    "modules-right": [ "pulseaudio", "network", "disk", "battery", "sway/language" ],
    "output": ["eDP-1", "HDMI-A-1"],
    "spacing": 0,
    "margin": "10 10 0 10",
    "start_hidden": true,
    "ipc": true,

    "sway/language": {
        "format": "<span font='16' rise='-3000'>¾░īī</span> {long}",
        "on-click": "swaymsg input type:keyboard xkb_switch_layout next",
    },

    "disk": {
        "interval": 1800,
        "format": "<span font='16' rise='-3000'>’éĀ</span> {free}",
        "path": "/home",
        "tooltip-format": "{free} available"
    },

    "mpd": {
         "format": "{stateIcon} {artist} - {title}",
         "on-click": "mpc toggle",
         "state-icons": {
             "playing": "<span font='11'>’Ćü</span>",
             "paused": "<span font='11'>’üī</span>",
         }
    },

    "sway/workspaces": {
        "all-outputs": true,
        "format": "{index}",
    },

    "battery": {
        "bat": "BAT1",
        "format-icons": [
            "<span font='10'>¾░ü║</span>",
            "<span font='10'>¾░ü╗</span>",
            "<span font='10'>¾░ü╝</span>",
            "<span font='10'>¾░üĮ</span>",
            "<span font='10'>¾░üŠ</span>",
            "<span font='10'>¾░ü┐</span>",
            "<span font='10'>¾░éĆ</span>",
            "<span font='10'>¾░éü</span>",
            "<span font='10'>¾░éé</span>",
            "<span font='10'>¾░ü╣</span>",
        ],
        "states": {
            "good": 100,
            "average": 60,
            "warning": 35,
            "critical": 20
        },
        "format": "{icon} {capacity}%",
        "tooltip-format": "{capacity}%"
    },

    "network": {
        "format-wifi": "<span rise='-4000' font='18'>¾░ż¬</span> {essid}",
        "format-ethernet": "<span rise='-4000' font='18'>¾░łĆ</span>",
        "format-disconnected": "<span rise='-4000' font='18'>¾░īÖ</span>",
        "states": {
            "good": 100,
            "average": 60,
            "warning": 30,
            "critical": 20,
        },
        "tooltip-format": "{essid} {signalStrength}%",
    },

    "clock": {
        "format": "<span font='16' rise='-4000'>’ü│</span> {:%A, %B %d, %Y %H:%M}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode"          : "year",
            "mode-mon-col"  : 3,
            "weeks-pos"     : "right",
            "on-scroll"     : 1,
            "on-click-right": "mode",
            "format": {
                "months":     "<span color='#ffead3'><b>{}</b></span>",
                "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions":  {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "<span font='16'>¾░Ø¤</span>",
        "format-icons": [
            "<span font='8'>¾░Ģ┐</span>",
            "<span font='12' rise='-2000'>¾░¢Ć</span>",
            "<span font='14' rise='-2000'>¾░ĢŠ</span>",
        ],
        "states": {
            "loud": 70,
            "average": 50,
            "quiet": 10
        },
        "tooltip-format": "{volume}%"
    },
}
